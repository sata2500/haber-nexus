// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  name          String?
  image         String?
  bio           String?   @db.Text
  password      String?   // For email/password auth
  role          UserRole  @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  articles      Article[]
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]
  followers     Follow[]   @relation("Following")
  following     Follow[]   @relation("Followers")
  notifications Notification[]
  
  // Author specific
  authorProfile AuthorProfile?
  
  @@index([email])
  @@index([username])
  @@index([role])
}

enum UserRole {
  USER
  AUTHOR
  EDITOR
  ADMIN
  SUPER_ADMIN
}

model AuthorProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  expertise       String[]
  socialLinks     Json?
  verified        Boolean   @default(false)
  verifiedAt      DateTime?
  
  // Stats
  totalArticles   Int       @default(0)
  totalViews      Int       @default(0)
  totalLikes      Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
  @@index([verified])
}

// ============================================
// NEXTAUTH MODELS
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// CONTENT MANAGEMENT
// ============================================

model Article {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  excerpt         String?       @db.Text
  content         String        @db.Text
  coverImage      String?
  
  // Categorization
  type            ArticleType   @default(NEWS)
  status          ArticleStatus @default(DRAFT)
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  tags            Tag[]
  
  // Author
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  
  // AI features
  aiGenerated     Boolean       @default(false)
  aiSummary       String?       @db.Text
  aiTags          String[]
  sourceRssId     String?
  sourceRss       RssFeed?      @relation(fields: [sourceRssId], references: [id])
  
  // SEO
  metaTitle       String?
  metaDescription String?       @db.Text
  keywords        String[]
  
  // Stats
  viewCount       Int           @default(0)
  likeCount       Int           @default(0)
  commentCount    Int           @default(0)
  shareCount      Int           @default(0)
  
  // Dates
  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  comments        Comment[]
  likes           Like[]
  bookmarks       Bookmark[]
  
  @@index([slug])
  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([type])
  @@index([publishedAt])
  @@index([aiGenerated])
}

enum ArticleType {
  NEWS
  BLOG
  ANALYSIS
  INTERVIEW
  OPINION
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?    @db.Text
  icon        String?
  color       String?
  
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  
  articles    Article[]
  rssFeeds    RssFeed[]
  
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([slug])
  @@index([parentId])
  @@index([isActive])
}

model Tag {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  
  articles  Article[]
  
  useCount  Int       @default(0)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  @@index([slug])
  @@index([useCount])
}

// ============================================
// SOCIAL FEATURES
// ============================================

model Comment {
  id          String        @id @default(cuid())
  content     String        @db.Text
  
  articleId   String
  article     Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Nested comments
  parentId    String?
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]     @relation("CommentReplies")
  
  // Moderation
  status      CommentStatus @default(PENDING)
  flagCount   Int           @default(0)
  
  // Stats
  likeCount   Int           @default(0)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([articleId])
  @@index([userId])
  @@index([parentId])
  @@index([status])
  @@index([createdAt])
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model Like {
  id        String   @id @default(cuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
}

model Bookmark {
  id        String   @id @default(cuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
}

model Follow {
  id          String   @id @default(cuid())
  
  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  
  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id        String           @id @default(cuid())
  
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  
  isRead    Boolean          @default(false)
  
  createdAt DateTime         @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  COMMENT
  LIKE
  FOLLOW
  MENTION
  ARTICLE
  SYSTEM
}

// ============================================
// RSS & AI FEATURES
// ============================================

model RssFeed {
  id              String       @id @default(cuid())
  name            String
  url             String       @unique
  description     String?      @db.Text
  
  // Category
  categoryId      String?
  category        Category?    @relation(fields: [categoryId], references: [id])
  
  // Settings
  isActive        Boolean      @default(true)
  scanInterval    Int          @default(60) // minutes
  priority        Int          @default(1)  // 1-10
  
  // Stats
  lastScannedAt   DateTime?
  totalScans      Int          @default(0)
  totalArticles   Int          @default(0)
  successRate     Float        @default(0)
  
  // AI filtering
  minQualityScore Float        @default(0.5)
  autoPublish     Boolean      @default(false)
  
  // Relations
  articles        Article[]
  scanLogs        RssScanLog[]
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([url])
  @@index([isActive])
  @@index([lastScannedAt])
}

model RssScanLog {
  id              String     @id @default(cuid())
  
  rssFeedId       String
  rssFeed         RssFeed    @relation(fields: [rssFeedId], references: [id], onDelete: Cascade)
  
  status          ScanStatus
  itemsFound      Int        @default(0)
  itemsProcessed  Int        @default(0)
  itemsPublished  Int        @default(0)
  
  error           String?    @db.Text
  duration        Int?       // milliseconds
  
  createdAt       DateTime   @default(now())
  
  @@index([rssFeedId])
  @@index([status])
  @@index([createdAt])
}

enum ScanStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model AiTask {
  id          String      @id @default(cuid())
  type        AiTaskType
  status      TaskStatus  @default(PENDING)
  priority    Int         @default(1)
  
  // Input/Output
  input       Json
  output      Json?
  
  // Related resources
  articleId   String?
  rssFeedId   String?
  
  // Error handling
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  error       String?     @db.Text
  
  // Scheduling
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([type])
  @@index([status])
  @@index([scheduledAt])
  @@index([priority])
}

enum AiTaskType {
  RSS_SCAN
  CONTENT_GENERATE
  SUMMARIZE
  TAG_GENERATE
  TREND_ANALYSIS
  QUALITY_CHECK
}

enum TaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}
